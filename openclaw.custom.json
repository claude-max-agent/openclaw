{
  "$schema": "./openclaw.schema.json",
  "_comment": "Admin専用カスタム版 OpenClaw設定 (Issue #15)",
  "_comment2": "RTX 3050 8GB VRAM向け最適化 / Ollama + 自前APIキーのみ",

  "plugins": {
    "enabled": true,
    "allow": [
      "ollama",
      "anthropic",
      "memory-core",
      "memory-lancedb",
      "llm-task",
      "diagnostics-otel"
    ],
    "deny": [
      "openai",
      "google",
      "amazon-bedrock",
      "openrouter",
      "perplexity",
      "mistral",
      "xai",
      "together",
      "huggingface",
      "sglang",
      "vllm",
      "github-copilot",
      "copilot-proxy",
      "shared",
      "kilocode",
      "kimi-coding",
      "cloudflare-ai-gateway",
      "vercel-ai-gateway",
      "chutes",
      "lobster",
      "venice",
      "byteplus",
      "volcengine",
      "nvidia",
      "minimax",
      "modelstudio",
      "moonshot",
      "qianfan",
      "qwen-portal-auth",
      "zai",
      "xiaomi",
      "open-prose",
      "opencode",
      "opencode-go",
      "openshell",
      "acpx",
      "synthetic",
      "fal"
    ]
  },

  "models": {
    "mode": "replace",
    "providers": {
      "ollama": {
        "baseUrl": "http://localhost:11434",
        "api": "ollama",
        "apiKey": "ollama-local",
        "models": [
          {
            "id": "llama3.2:3b",
            "name": "Llama 3.2 3B (RTX 3050向け軽量)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8192,
            "maxTokens": 4096,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          },
          {
            "id": "llama3.1:8b",
            "name": "Llama 3.1 8B (RTX 3050 8GB VRAM上限)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8192,
            "maxTokens": 4096,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          },
          {
            "id": "qwen2.5:7b",
            "name": "Qwen 2.5 7B",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8192,
            "maxTokens": 4096,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          },
          {
            "id": "gemma2:2b",
            "name": "Gemma 2 2B (超軽量)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8192,
            "maxTokens": 4096,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": "ollama/llama3.1:8b",
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 1
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },

  "gateway": {
    "auth": {
      "rateLimit": {
        "maxAttempts": 5,
        "windowMs": 60000,
        "lockoutMs": 600000
      }
    }
  },

  "logging": {
    "redactSensitive": "tools"
  }
}
